# Test account credentials (main coach account)
TEST_USER_ID=your_test_email@example.com
TEST_USER_PW=your_password

# Registration test password (used when creating new test accounts)
TEST_REG_PW=your_registration_password

# Jira integration
JIRA_BASE_URL=https://your-domain.atlassian.net/
JIRA_EMAIL=your_jira_email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=QA

# Download directory (absolute path)
DOWNLOAD_DIR=C:/Users/YourName/Downloads

# Slack Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_WEBHOOK_FAILURES_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# API timeout in seconds
DEFAULT_API_TIMEOUT=10
